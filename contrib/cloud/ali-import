ECS_ENDPOINT = 'ecs.aliyuncs.com'
FC_NODE_RUNTIME = 'nodejs20'
OSS_FORBIDDEN_REGION_CODE = 'ForbidCreateNewBucket'

IPXE_STORAGE_PREFIX = 'ipxe-upload-temp-'

def ecs_client(region=None):
    """Get elastic compute service client"""
    cred = credentials.client.Client()
    conf = openapi.models.Config(
        credential=cred,
        region_id=region,
        endpoint=ECS_ENDPOINT if region is None else None,
    )
    client = ecs.client.Client(conf)
    return client

def fc_client(region):
    """Get function compute client"""
    cred = credentials.client.Client()
    conf = openapi.models.Config(credential=cred, region_id=region)
    client = fc.client.Client(conf)
    return client

def oss_client(region):
    """Get object storage client"""
    cred = oss.credentials.EnvironmentVariableCredentialsProvider()
    conf = oss.config.Config(credentials_provider=cred, region=region)
    client = oss.client.Client(conf)
    return client

def all_regions():
    """Get list of all regions"""
    client = ecs_client()
    req = ecs.models.DescribeRegionsRequest()
    rsp = client.describe_regions(req)
    regions = sorted(x.region_id for x in rsp.body.regions.region)
    return regions





def create_temp_function(region):
    """Create function to bypass moronic Chinese censorship restrictions"""
    client = fc_client(region)
    func = '''
    const fs = require("fs"), path = "/mnt/oss/";
    exports.handler = async (event, context) => {
      let name = context.http.headers["x-filename"];
      if (name) {
        fs.writeFileSync(path + name, event);
      } else {
        for (const x of fs.readdirSync(p))
          fs.unlinkSync(path + x);
      }
    };
    '''.lstrip()
    buf = io.BytesIO()
    with zipfile.ZipFile(buf, 'w') as zfh:
        zfh.writestr('index.js', func)
    zf = base64.b64encode(buf.getvalue()).decode()
    code = fc.models.InputCodeLocation(zip_file=zf)
    name = '%s%s' % (IPXE_STORAGE_PREFIX, uuid4())
    body = fc.models.CreateFunctionInput(
        function_name=name,
        runtime=FC_NODE_RUNTIME,
        handler='index.handler',
    )
    req = fc.models.CreateFunctionRequest(body=body)
    rsp = client.create_function(req)
    return name

def delete_temp_bucket(region, bucket):
    """Remove temporary bucket"""
    client = oss_client(region)
    assert bucket.startswith(IPXE_STORAGE_PREFIX)
    req = oss.models.ListObjectsV2Request(
        bucket=bucket,
        prefix=IPXE_STORAGE_PREFIX,
    )
    #rsp = client.list_objects_v2(req)
    #objs = [oss.models.DeleteObject(x.key) for x in rsp.contents or ()]
    objs = ()
    for obj in objs:
        assert obj.key.startswith(IPXE_STORAGE_PREFIX)
    req = oss.models.DeleteMultipleObjectsRequest(bucket=bucket, objects=objs)
    if objs:
        client.delete_multiple_objects(req)
    req = oss.models.DeleteBucketRequest(bucket=bucket)
    client.delete_bucket(req)

def create_temp_bucket(region):
    """Create temporary bucket (and remove any stale temporary buckets)"""
    client = oss_client(region)
    req = oss.models.ListBucketsRequest(prefix=IPXE_STORAGE_PREFIX)
    rsp = client.list_buckets(req)
    buckets = [x.name for x in rsp.buckets or () if x.region == region]
    for bucket in buckets:
        delete_temp_bucket(region, bucket)
    bucket = '%s%s' % (IPXE_STORAGE_PREFIX, uuid4())
    req = oss.models.PutBucketRequest(bucket=bucket)
    try:
        rsp = client.put_bucket(req)
    except oss.exceptions.OperationError as exc:
        # AliCloud provides no other way to detect non-functional regions
        if exc.unwrap().code == OSS_FORBIDDEN_REGION_CODE:
            bucket = None
        else:
            raise exc
    return bucket

def upload_image(region, bucket, image):
    """Upload disk image to bucket"""
    client = oss_client(region)
    key = '%s%s' % (IPXE_STORAGE_PREFIX, uuid4())
    req = oss.models.PutObjectRequest(bucket=bucket, key=key)
    rsp = client.put_object_from_file(req, image)
    return key


